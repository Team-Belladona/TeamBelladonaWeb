---
layout: base-en.njk
title: Team Belladona
---

<section class="hero">
  <div class="hero-title">
    <p class="hero-sub">team</p>
    <div class="hero-main">
      <span class="hero-char" style="--i:0">B</span>
      <span class="hero-char" style="--i:1">e</span>
      <span class="hero-char" style="--i:2">l</span>
      <span class="hero-char" style="--i:3">l</span>
      <span class="hero-char" style="--i:4">a</span>
      <span class="hero-char" style="--i:5">D</span>
      <span class="hero-char" style="--i:6">o</span>
      <span class="hero-char" style="--i:7">n</span>
      <span class="hero-char" style="--i:8">a</span>
    </div>
  </div>
</section>

<div class="content-wrap">

  <!-- PROJECTS -->
  <section class="projects" id="projects">
    <h2>GAMES</h2>
    <div class="game-entry">
      <a href="/devlog">
        <img src="/assets/game-logo.png" alt="ELSEWHERE" class="game-logo-big">
      </a>
      <div class="game-desc">
        <p class="game-genre">Narrative Turn-Based Timing Black Comedy ARPG, ELSEWHERE.</p>
        <p class="game-summary">Anne’s dark-comedy odyssey into Elsewhere: To save her brother—and, you know, the world!</p>
      </div>
    </div>
  </section>

  <!-- DEVLOG -->
  <section class="devlog-preview" id="devlog">
<!-- DEVLOG -->
<section class="devlog-preview" id="devlog">
  <h2>DEVLOG</h2>
  <div class="devlog-preview-list">
    {%- for post in collections.elsewhereEn | reverse | limit(3) %}
    <a href="{{ post.url }}" class="devlog-preview-item">
      <div class="devlog-preview-thumb">
        {% set thumb = post.templateContent | firstImage %}
        {% if thumb %}
          <img src="{{ thumb }}" alt="{{ post.data.title }}">
        {% else %}
          <p class="devlog-preview-excerpt">{{ post.templateContent | striptags | truncate(80) }}</p>
        {% endif %}
      </div>
      <div class="devlog-preview-info">
        <p class="devlog-tag">ELSEWHERE</p>
        <h3 class="devlog-title">{{ post.data.title }}</h3>
      </div>
    </a>
    {%- endfor %}
  </div>
  <a href="/en/devlog" class="btn">View All</a>
</section>

  <!-- TEAM -->
  <section class="team" id="team">
    <h2>TEAM</h2>
    <div class="member-grid">
      <div class="member">
        <p class="member-name">효니(Hyoni)</p>
        <p class="member-role">Game Design · Art · PM</p>
        </div>
      <div class= "member">
        <p class= "member-name"> 판테라(Panthera)</p>
        <p class= "member-role"> Programmer · Game Design
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact" id="contact">
    <h2>CONTACT</h2>
    <form class="contact-form" method="POST" action="https://formspree.io/f/xykbzpeo">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" placeholder="John Doe" required>
      </div>
      <div class="form-group">
        <label for="email">E-mail</label>
        <input type="email" id="email" name="email" placeholder="john.doe@example.com" required>
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="5" placeholder="Hi!" required></textarea>
      </div>
      <button type="submit" class="btn">Send</button>
    </form>
  </section>

</div>