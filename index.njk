<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <script>
    const lang = navigator.language || navigator.userLanguage || '';
    if (lang.startsWith('ja')) location.replace('/ja/');
    else if (lang.startsWith('ko')) location.replace('/ko/');
    else location.replace('/en/');
  </script>
</head>
<body></body>
</html>
