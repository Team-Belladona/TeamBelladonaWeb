---
layout: base.njk
title: Team Belladona
---

<section class="hero">
  <div class="hero-title">
    <p class="hero-sub">team</p>
    <div class="hero-main">
      <span class="hero-char" style="--i:0">B</span>
      <span class="hero-char" style="--i:1">e</span>
      <span class="hero-char" style="--i:2">l</span>
      <span class="hero-char" style="--i:3">l</span>
      <span class="hero-char" style="--i:4">a</span>
      <span class="hero-char" style="--i:5">D</span>
      <span class="hero-char" style="--i:6">o</span>
      <span class="hero-char" style="--i:7">n</span>
      <span class="hero-char" style="--i:8">a</span>
    </div>
  </div>
</section>

<!-- CONTENT -->
<div class="content-wrap">

  <!-- PROJECTS -->
<section class="projects fade-in" id="projects">
  <h2>GAMES</h2>
  <a href="/devlog">
    <img src="/assets/game-logo.png" alt="ELSEWHERE" class="game-logo-big">
  </a>
</section>

<!-- DEVLOG -->
<section class="devlog-preview" id="devlog">
  <h2>DEVLOG</h2>
  <div class="devlog-preview-list">
    {%- for post in collections.elsewhere | reverse | limit(3) %}
    <a href="{{ post.url }}" class="devlog-preview-item">
      <div class="devlog-preview-thumb">
        {% set thumb = post.templateContent | firstImage %}
        {% if thumb %}
          <img src="{{ thumb }}" alt="{{ post.data.title }}">
        {% else %}
          <p class="devlog-preview-excerpt">{{ post.templateContent | striptags | truncate(80) }}</p>
        {% endif %}
      </div>
      <div class="devlog-preview-info">
        <p class="devlog-tag">ELSEWHERE</p>
        <h3 class="devlog-title">{{ post.data.title }}</h3>
      </div>
    </a>
    {%- endfor %}
  </div>
  <a href="/devlog" class="btn">전체 보기</a>
</section>

  <!-- TEAM -->
  <section class="team fade-in" id="team">
    <h2>TEAM</h2>
    <div class="member-grid">
      <div class="member">
        <p class="member-name">효니</p>
        <p class="member-role">기획 · 아트 · PM</p>
      </div>
      <div class="member">
        <p class="member-name">곰팡이</p>
        <p class="member-role">VFX</p>
      </div>
      <div class="member">
        <p class="member-name">사차지</p>
        <p class="member-role">QA · 기획보조</p>
      </div>
      <div class="member">
        <p class="member-name">기타만세</p>
        <p class="member-role">SFX · BGM</p>
      </div>
      <div class="member">
        <p class="member-name">루이딘</p>
        <p class="member-role">프로그래머</p>
      </div>
    </div>
  </section>

<section class="contact fade-in" id="contact">
  <h2>CONTACT</h2>
  <form class="contact-form" name="contact" method="POST" netlify>
    <input type="hidden" name="form-name" value="contact">
    <div class="form-group">
      <label for="name">이름</label>
      <input type="text" id="name" name="name" placeholder="John Doe" required>
    </div>
    <div class="form-group">
      <label for="email">이메일</label>
      <input type="email" id="email" name="email" placeholder="john.doe@example.com" required>
    </div>
    <div class="form-group">
      <label for="message">메시지</label>
      <textarea id="message" name="message" rows="5" placeholder="Hi!" required></textarea>
    </div>
    <button type="submit" class="btn">보내기</button>
  </form>
</section>

</div>